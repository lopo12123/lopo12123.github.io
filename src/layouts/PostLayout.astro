---
import type { BlogFrontMatter } from "../types";
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

interface Props {
    post: BlogFrontMatter
}

const { post } = Astro.props
const { title, description, category, publishDate, updatedDate } = post;
---

<html lang="zh-CN">
    <head>
        <BaseHead title={ title } description={ description }/>
        <style>
            main {
                width: calc(100% - 2em);
                max-width: 100%;
                margin: 0;
            }

            .prose {
                width: 720px;
                max-width: calc(100% - 2em);
                margin: auto;
                padding: 1em;
                color: rgb(var(--gray-dark));
            }

            .title {
                text-align: center;
                line-height: 1;
            }

            .metadata {
                margin-bottom: 0.5em;
                font-size: 0.8em;
                color: rgb(var(--gray));
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .floating-buttons {
                position: fixed;
                z-index: 1;
                bottom: 1em;
                right: 1em;
                display: flex;
                flex-direction: column;
                gap: 0.5em;

                .op-button {
                    width: 3em;
                    height: 3em;
                    border-radius: 0.5em;
                    background-color: white;
                    box-shadow: var(--box-shadow-more);
                    font-size: 0.8em;
                    cursor: pointer;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                }
            }
        </style>
    </head>

    <body>
        <Header/>
        <main>
            <article>
                <div class="prose">
                    <div class="title">
                        <h1>{ title }</h1>
                        <div class="metadata">
                            <div>
                                {
                                    category
                                        ? (
                                            <span>In Category</span>
                                            <span>《{ category }》</span>
                                        )
                                        : <span>No category</span>
                                }
                            </div>
                            <span>,&nbsp;</span>
                            <div>
                                <span>Published on</span>
                                <FormattedDate date={ publishDate }/>
                            </div>
                            {
                                updatedDate && (
                                    <span>,&nbsp;</span>
                                    <div>
                                        <span>Updated on</span>
                                        <FormattedDate date={ updatedDate }/>
                                    </div>
                                )
                            }
                        </div>
                        <hr class="solid"/>
                    </div>
                    <slot/>
                </div>
            </article>

            <div class="floating-buttons">
                <!-- TODO: outline menu -->
                <div class="op-button" title="Back to Top" onclick="back2top()">↑</div>
                <div class="op-button" title="Back to Previous Page" onclick="back2blog()">←</div>
            </div>
        </main>

        <Footer/>

        <script is:inline>
            function back2blog() {
                window.location.href = '/blog';
            }

            function back2top() {
                window.scrollTo({
                    top: 0,
                    behavior: 'smooth'
                });
            }
        </script>
    </body>

</html>
