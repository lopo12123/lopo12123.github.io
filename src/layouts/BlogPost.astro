---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, category, publishDate, updatedDate } = Astro.props as Props;
---

<html lang="zh-CN">
    <head>
        <BaseHead title={ title } description={ description }/>
        <style>
            main {
                width: calc(100% - 2em);
                max-width: 100%;
                margin: 0;
            }

            .prose {
                width: 720px;
                max-width: calc(100% - 2em);
                margin: auto;
                padding: 1em;
                color: rgb(var(--gray-dark));
            }

            .title {
                text-align: center;
                line-height: 1;
            }

            .metadata {
                margin-bottom: 0.5em;
                font-size: 0.8em;
                color: rgb(var(--gray));
                display: flex;
                align-items: center;
                justify-content: center;
            }
        </style>
    </head>

    <body>
        <Header/>
        <main>
            <article>
                <div class="prose">
                    <div class="title">
                        <h1>{ title }</h1>
                        <div class="metadata">
                            <div>
                                {
                                    category
                                        ? (
                                            <span>In Category</span>
                                            <span>《{ category }》</span>
                                        )
                                        : <span>No category</span>
                                }
                            </div>
                            <span>,&nbsp;</span>
                            <div>
                                <span>Published on</span>
                                <FormattedDate date={ publishDate }/>
                            </div>
                            {
                                updatedDate && (
                                    <span>,&nbsp;</span>
                                    <div>
                                        <span>Updated on</span>
                                        <FormattedDate date={ updatedDate }/>
                                    </div>
                                )
                            }
                        </div>
                        <hr class="solid"/>
                    </div>
                    <slot/>
                </div>
            </article>
        </main>

        <Footer/>
    </body>
</html>
